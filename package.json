{
  "name": "extrasure",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate --schema prisma/schema.prisma && next dev",
    "build": "node scripts/prisma-prepare.mjs && next build",
    "build:vercel": "node scripts/prisma-prepare.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --runInBand",
    "db:generate": "node scripts/prisma-prepare.mjs",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgresql.prisma",
    "db:push": "prisma db push",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgresql.prisma",
    "db:seed": "prisma db seed",
    "db:dedupe:technicians": "node --env-file=.env scripts/dedupe-technicians.mjs",
    "db:purge:triage": "node --env-file=.env scripts/purge-triage-retention.mjs",
    "db:seed:prod": "prisma generate --schema prisma/schema.postgresql.prisma && tsx prisma/seed-production.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.177",
    "next": "16.2.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
